---
import '@fontsource/playfair-display/400.css';
import { WA_URL, siteConfig, contactConfig, featureFlags, brandingConfig } from '../config/site';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/500-italic.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/open-sauce-one/300.css';
import '@fontsource/open-sauce-one/400.css';
import '@fontsource/open-sauce-one/600.css';
import '@fontsource/open-sauce-one/700.css';
import '../styles/global.css';
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import logoSimbolo from '../assets/img/logo-novo-simbolo.png';

interface Props {
  title: string;
  description: string;
  schema?: Record<string, unknown>[];
  /* força noindex mesmo em produção (páginas inativas/rascunho) */
  noindex?: boolean;
}
const { title, description, schema = [], noindex = false } = Astro.props;
/* SEO por ambiente: em preview (noindex) NÃO afirmamos canonical do domínio
   oficial — só em produção. */
const isPreview = Boolean(import.meta.env.PUBLIC_NOINDEX) || !siteConfig.allowIndexing;
const canonical = new URL(Astro.url.pathname, siteConfig.productionUrl).href;
const base = import.meta.env.PUBLIC_BASE ?? '';
const ogImage = isPreview ? `${base}/og-image.jpg` : new URL('/og-image.jpg', siteConfig.productionUrl).href;
const anoAtual = new Date().getFullYear();
---
<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {(isPreview || noindex) && <meta name="robots" content="noindex, nofollow" />}
    {!isPreview && !noindex && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#e9e3d5" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Hipnose Resolve — Clínica de Reprogramação Mental" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {schema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <noscript><style>{`.reveal{opacity:1 !important;transform:none !important}`}</style></noscript>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Saltar para o conteúdo</a>
    <header class="header">
      <div class="wrap header__in">
        <a class="logo" href="/">
          <Image src={logoSimbolo} alt="Hipnose Resolve" widths={[112, 190]} sizes="54px" class="logo__img" />
          <span class="logo__txt">Hipnose <em>Resolve</em><small>Clínica de Reprogramação Mental</small></span>
        </a>
        <nav class="nav" id="nav" aria-label="Navegação principal">
          <a href="/areas">Terapias</a>
          <a href="/programas">Programas</a>
          <a href="/consultas">Como Funciona</a>
          <a href="/equipa">Quem Somos</a>
          <a href="/blog">Blog</a>
          <a href="/contactos">Contactos</a>
          {featureFlags.membersAreaEnabled && <a href="/membros" class="nav__extra">Área de Membros</a>}
        </nav>
        <a class="btn btn--gold" href="/consultas">Marcar consulta</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav" aria-label="Abrir menu">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
        </button>
      </div>
    </header>

    <main id="conteudo">
      <slot />
    </main>

    <footer class="footer" id="contactos">
      <div class="wrap">
        <div class="footer__grid">
          <div>
            <a class="logo" href="/">
              <Image src={logoSimbolo} alt="Hipnose Resolve" widths={[112, 190]} sizes="54px" class="logo__img" />
              <span class="logo__txt">Hipnose <em>Resolve</em><small>Clínica de Reprogramação Mental</small></span>
            </a>
            <p style="margin-top:1.2rem; max-width:34ch;">
              Clínica de Reprogramação Mental — reprogramamos mentes e comportamentos, online e presencial. Portugal e Brasil.
            </p>
            <p style="margin-top:1rem; font-size:.86rem; line-height:1.8;">
              {contactConfig.address.street}<br />{contactConfig.address.postalCode} {contactConfig.address.city} · {contactConfig.address.country}<br />
              <a href={`tel:${contactConfig.phone}`}>{contactConfig.phoneDisplay}</a><br />
              <a href={`mailto:${contactConfig.generalEmail}`}>{contactConfig.generalEmail}</a>
            </p>
            <div class="footer__selos" aria-label="Garantias">
              <span>RGPD</span>
              <span>Pagamentos seguros</span>
              <span>Livro de Reclamações</span>
              <span>PT &amp; BR</span>
            </div>
          </div>
          <div>
            <h4>Navegar</h4>
            <ul>
              <li><a href="/areas">Terapias</a></li>
              <li><a href="/programas">Programas</a></li>
              <li><a href="/consultas">Como funciona</a></li>
              <li><a href="/viseu">Gabinete de Viseu</a></li>
              <li><a href="/equipa">Sobre nós</a></li>
              <li><a href="/blog">Blog</a></li>
              {featureFlags.membersAreaEnabled && <li><a href="/membros">Área de Membros</a></li>}
            </ul>
          </div>
          <div>
            <h4>Legal</h4>
            <ul>
              <li><a href="/politica-privacidade">Política de Privacidade</a></li>
              <li><a href="https://www.livroreclamacoes.pt" rel="noopener" target="_blank">Livro de Reclamações Eletrónico</a></li>
              <li><a href="/termos">Termos dos Programas</a></li>
            </ul>
          </div>
          <div>
            <h4>Siga-nos</h4>
            <p style="font-size:.88rem;">Conteúdos sobre a mente e a mudança, todas as semanas.</p>
            {featureFlags.newsletterEnabled && (
              <form class="news" aria-label="Subscrever newsletter">
                <input type="email" placeholder="O seu melhor email" aria-label="Email" />
                <button type="submit">→</button>
              </form>
            )}
            <p style="margin-top:1.2rem; font-size:.86rem;">
              <a href={contactConfig.instagram} target="_blank" rel="noopener noreferrer">Instagram</a> ·
              <a href={contactConfig.facebook} target="_blank" rel="noopener noreferrer">Facebook</a> ·
              <a href={WA_URL} target="_blank" rel="noopener noreferrer">WhatsApp</a>
            </p>
          </div>
        </div>
        <p class="footer__legal">
          A hipnoterapia é uma prática complementar de bem-estar e não substitui o diagnóstico,
          acompanhamento ou tratamento médico ou psicológico. Os resultados variam de pessoa para pessoa
          e nenhum resultado específico é garantido. Em caso de emergência, contacte o 112 (PT) ou o CVV 188 (BR).
          <br />© {anoAtual} {siteConfig.siteName} · Website desenvolvido pela <a href={brandingConfig.developerUrl} target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: underline; text-underline-offset: 3px;">{brandingConfig.developerName}</a>
        </p>
      </div>
    </footer>

    <div class="wa-teaser" id="waTeaser" role="status" hidden>
      <button class="wa-teaser__fechar" type="button" aria-label="Fechar mensagem">×</button>
      <a href={WA_URL} target="_blank" rel="noopener noreferrer">
        <b>Olá! 👋 Posso ajudar?</b>
        <span>Fale connosco no WhatsApp — respondemos rápido.</span>
      </a>
    </div>
    <a class="wa-float" href={WA_URL} aria-label="Falar no WhatsApp" target="_blank" rel="noopener">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1l-.8 1c-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.3-2.9c-.2-.4.2-.4.5-1 .1-.2 0-.4 0-.5l-.8-1.8c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.9.9-1.2 2.1-.6 3.5.8 1.9 2.3 3.6 4.2 4.7 1.4.8 2.5 1 3.4.8.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2 0-.2-.2-.3-.8-.7Z"/></svg>
    </a>

    <script>
      /* Setup por página, compatível com View Transitions:
         corre em astro:page-load e limpa listeners antigos via AbortController. */
      let ctrl: AbortController | undefined;

      const init = () => {
        ctrl?.abort();
        ctrl = new AbortController();
        const { signal } = ctrl;
        const reduz = matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Chat teaser do WhatsApp — aparece após 20s, uma vez por sessão
        const teaser = document.getElementById('waTeaser');
        if (teaser && !sessionStorage.getItem('waTeaserVisto')) {
          const t = setTimeout(() => { teaser.hidden = false; requestAnimationFrame(() => teaser.classList.add('in')); }, 20000);
          signal.addEventListener('abort', () => clearTimeout(t));
          teaser.querySelector('.wa-teaser__fechar')?.addEventListener('click', () => {
            teaser.classList.remove('in');
            sessionStorage.setItem('waTeaserVisto', '1');
            setTimeout(() => { teaser.hidden = true; }, 350);
          }, { signal });
          teaser.querySelector('a')?.addEventListener('click', () => sessionStorage.setItem('waTeaserVisto', '1'), { signal });
        }

        // Menu mobile
        const toggle = document.querySelector('.nav-toggle');
        const nav = document.getElementById('nav');
        toggle?.addEventListener('click', () => {
          const open = nav!.classList.toggle('open');
          toggle.setAttribute('aria-expanded', String(open));
        }, { signal });

        // Reveals suaves — movimento que acalma, não que distrai
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          }),
          { threshold: 0.14 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
        signal.addEventListener('abort', () => io.disconnect());

        // Carrossel de terapias — setas + autoplay (pausa ao interagir)
        document.querySelectorAll<HTMLElement>('[data-caro]').forEach((c) => {
          const track = c.querySelector<HTMLElement>('.caro__track');
          if (!track) return;
          const passo = () => (track.firstElementChild?.clientWidth ?? 320) + 19;
          const avanca = (dir: number) => {
            const fim = track.scrollLeft + track.clientWidth >= track.scrollWidth - 8;
            if (dir > 0 && fim) track.scrollTo({ left: 0, behavior: 'smooth' });
            else track.scrollBy({ left: dir * passo(), behavior: 'smooth' });
          };
          c.querySelector('[data-caro-prev]')?.addEventListener('click', () => avanca(-1), { signal });
          c.querySelector('[data-caro-next]')?.addEventListener('click', () => avanca(1), { signal });
          if (!reduz) {
            let timer = setInterval(() => avanca(1), 3800);
            const pausa = () => { clearInterval(timer); timer = setInterval(() => avanca(1), 3800); };
            ['pointerenter', 'pointerdown', 'touchstart'].forEach((ev) =>
              c.addEventListener(ev, pausa, { passive: true, signal })
            );
            signal.addEventListener('abort', () => clearInterval(timer));
          }
        });

        // Sombra do header ao rolar
        const header = document.querySelector('.header');
        const onHeaderScroll = () => header?.classList.toggle('header--scrolled', scrollY > 24);
        addEventListener('scroll', onHeaderScroll, { passive: true, signal });
        onHeaderScroll();

        // Vídeo ambiente: retoma após view transitions; respeita reduced-motion
        document.querySelectorAll<HTMLVideoElement>('video[data-ambiente]').forEach((v) => {
          if (reduz) {
            v.removeAttribute('autoplay');
            v.pause();
          } else {
            v.muted = true; // após view transition a propriedade perde-se e o autoplay é bloqueado
            v.play().catch(() => {});
          }
        });

        // Contadores da banda de eficácia (sobem quando entram no ecrã)
        document.querySelectorAll<HTMLElement>('.compare__cell b').forEach((b) => {
          const alvo = parseInt(b.textContent ?? '', 10);
          if (!alvo || reduz) return;
          const ioNum = new IntersectionObserver((ents) => {
            if (!ents[0].isIntersecting) return;
            ioNum.disconnect();
            const t0 = performance.now();
            const tick = (t: number) => {
              const p = Math.min((t - t0) / 1300, 1);
              b.textContent = Math.round(alvo * (1 - Math.pow(1 - p, 3))) + '%';
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          }, { threshold: 0.6 });
          ioNum.observe(b);
          signal.addEventListener('abort', () => ioNum.disconnect());
        });

        // Manifesto — revelação palavra a palavra ao ritmo do scroll
        const manifesto = document.querySelector('.manifesto');
        if (manifesto) {
          const words = manifesto.querySelectorAll<HTMLElement>('.w');
          if (reduz) {
            words.forEach((w) => w.classList.add('on'));
          } else {
            const onScroll = () => {
              const r = manifesto.getBoundingClientRect();
              const done = Math.min(Math.max((innerHeight * 0.82 - r.top) / (r.height + innerHeight * 0.4), 0), 1);
              const n = Math.round(done * words.length);
              words.forEach((w, i) => w.classList.toggle('on', i < n));
            };
            addEventListener('scroll', onScroll, { passive: true, signal });
            onScroll();
          }
        }

        // Tilt 3D — cards seguem o rato (só ponteiro fino, sem reduced-motion)
        if (matchMedia('(pointer: fine)').matches && !reduz) {
          document.querySelectorAll<HTMLElement>('.spec-card, .card-l, .program, .why-card, .prog-card').forEach((el) => {
            el.classList.add('tilt3d');
            el.addEventListener('pointermove', (e) => {
              const r = el.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width - 0.5;
              const py = (e.clientY - r.top) / r.height - 0.5;
              el.style.setProperty('--ry', (px * 5).toFixed(2) + 'deg');
              el.style.setProperty('--rx', (-py * 5).toFixed(2) + 'deg');
              el.style.setProperty('--mx', ((px + 0.5) * 100).toFixed(1) + '%');
              el.style.setProperty('--my', ((py + 0.5) * 100).toFixed(1) + '%');
            }, { signal });
            el.addEventListener('pointerleave', () => {
              el.style.setProperty('--rx', '0deg');
              el.style.setProperty('--ry', '0deg');
            }, { signal });
          });
        }
      };

      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
