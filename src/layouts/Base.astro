---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/figtree';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  schema?: Record<string, unknown>[];
}
const { title, description, schema = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {import.meta.env.PUBLIC_NOINDEX && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#FAF6EF" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Hipnose Resolve" />
    <meta property="og:locale" content="pt_PT" />
    <meta name="twitter:card" content="summary" />
    {schema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <header class="header">
      <div class="wrap header__in">
        <a class="logo" href="/">
          <span class="monogram" aria-hidden="true">HR</span>
          <span class="logo__txt">Hipnose <em>Resolve</em><small>Clínica de Hipnoterapia</small></span>
        </a>
        <nav class="nav" id="nav" aria-label="Navegação principal">
          <a href="/areas">Terapias</a>
          <a href="/programas">Programas</a>
          <a href="/consultas">Como Funciona</a>
          <a href="/equipa">Sobre Nós</a>
          <a href="/blog">Blog</a>
          <a href="/contactos">Contactos</a>
          <a href="/membros" class="nav__extra">Área de Membros</a>
        </nav>
        <a class="btn btn--gold" href="/consultas">Marcar sessão</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav" aria-label="Abrir menu">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer" id="contactos">
      <div class="wrap">
        <div class="footer__grid">
          <div>
            <a class="logo" href="/">
              <span class="monogram" aria-hidden="true">HR</span>
              <span class="logo__txt">Hipnose <em>Resolve</em><small>Clínica de Hipnoterapia</small></span>
            </a>
            <p style="margin-top:1.2rem; max-width:34ch;">
              Clínica de hipnoterapia — reprogramamos mentes e comportamentos, online e presencial. Portugal e Brasil.
            </p>
            <p style="margin-top:1rem; font-size:.86rem; line-height:1.8;">
              Rua Dr. Álvaro Monteiro, 12 R/C dto.<br />3510-014 Viseu · Portugal<br />
              <a href="tel:+351915574759">+351 915 574 759</a><br />
              <a href="mailto:info@hipnoseresolve.pt">info@hipnoseresolve.pt</a>
            </p>
          </div>
          <div>
            <h4>Navegar</h4>
            <ul>
              <li><a href="/areas">Terapias</a></li>
              <li><a href="/programas">Programas</a></li>
              <li><a href="/consultas">Como funciona</a></li>
              <li><a href="/equipa">Sobre nós</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/membros">Área de Membros</a></li>
            </ul>
          </div>
          <div>
            <h4>Legal</h4>
            <ul>
              <li><a href="/politica-privacidade">Política de Privacidade</a></li>
              <li><a href="https://www.livroreclamacoes.pt" rel="noopener" target="_blank">Livro de Reclamações Eletrónico</a></li>
              <li><a href="/termos">Termos dos Programas</a></li>
            </ul>
          </div>
          <div>
            <h4>Newsletter</h4>
            <p style="font-size:.88rem;">Receba dicas e conteúdos exclusivos para o seu bem-estar.</p>
            <form class="news" onsubmit="return false;" aria-label="Subscrever newsletter">
              <input type="email" placeholder="O seu melhor email" aria-label="Email" />
              <button type="submit" title="Disponível brevemente">→</button>
            </form>
            <p style="margin-top:1.2rem; font-size:.86rem;">
              <a href="https://www.instagram.com/hipnoseresolve/" target="_blank" rel="noopener">Instagram</a> ·
              <a href="https://www.facebook.com/profile.php?id=61555999870032" target="_blank" rel="noopener">Facebook</a> ·
              <a href="https://wa.me/351915574759" target="_blank" rel="noopener">WhatsApp</a>
            </p>
          </div>
        </div>
        <p class="footer__legal">
          A hipnoterapia é uma prática complementar de bem-estar e não substitui o diagnóstico,
          acompanhamento ou tratamento médico ou psicológico. Os resultados variam de pessoa para pessoa
          e nenhum resultado específico é garantido. Em caso de emergência, contacte o 112 (PT) ou o CVV 188 (BR).
          <br />© 2026 Hipnose Resolve · Site por BRANCT TECH
        </p>
      </div>
    </footer>

    <a class="wa-float" href="https://wa.me/351915574759" aria-label="Falar no WhatsApp" target="_blank" rel="noopener">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1l-.8 1c-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.3-2.9c-.2-.4.2-.4.5-1 .1-.2 0-.4 0-.5l-.8-1.8c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.9.9-1.2 2.1-.6 3.5.8 1.9 2.3 3.6 4.2 4.7 1.4.8 2.5 1 3.4.8.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2 0-.2-.2-.3-.8-.7Z"/></svg>
    </a>

    <script>
      // Menu mobile
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.getElementById('nav');
      toggle?.addEventListener('click', () => {
        const open = nav!.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
      });

      // Reveals suaves — movimento que acalma, não que distrai
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }),
        { threshold: 0.14 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // Tilt 3D — cards seguem o rato (só ponteiro fino, sem reduced-motion)
      const podeTilt =
        matchMedia('(pointer: fine)').matches &&
        !matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (podeTilt) {
        document.querySelectorAll<HTMLElement>('.spec-card, .card-l, .program').forEach((el) => {
          el.classList.add('tilt3d');
          el.addEventListener('pointermove', (e) => {
            const r = el.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            el.style.setProperty('--ry', (px * 5).toFixed(2) + 'deg');
            el.style.setProperty('--rx', (-py * 5).toFixed(2) + 'deg');
            el.style.setProperty('--mx', ((px + 0.5) * 100).toFixed(1) + '%');
            el.style.setProperty('--my', ((py + 0.5) * 100).toFixed(1) + '%');
          });
          el.addEventListener('pointerleave', () => {
            el.style.setProperty('--rx', '0deg');
            el.style.setProperty('--ry', '0deg');
          });
        });
      }
    </script>
  </body>
</html>
