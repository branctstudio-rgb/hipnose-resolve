---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/figtree';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="header">
      <div class="wrap header__in">
        <a class="logo" href="/">Hipnose <em>Resolve</em><small>Clínica de Hipnoterapia</small></a>
        <nav class="nav" aria-label="Navegação principal">
          <a href="#areas">Áreas de Intervenção</a>
          <a href="#consultas">Consultas</a>
          <a href="#equipa">Equipa</a>
          <a href="#programas">Programas</a>
          <a href="#contactos">Contactos</a>
        </nav>
        <a class="btn btn--primary" href="#consultas">Marcar consulta</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer" id="contactos">
      <div class="wrap">
        <div class="footer__grid">
          <div>
            <a class="logo" href="/">Hipnose <em>Resolve</em><small>Clínica de Hipnoterapia</small></a>
            <p style="margin-top:1.2rem; max-width:34ch;">
              Hipnoterapia clínica, online e presencial. Portugal e Brasil, em português.
            </p>
          </div>
          <div>
            <h4>Navegar</h4>
            <ul>
              <li><a href="#areas">Áreas de intervenção</a></li>
              <li><a href="#consultas">Consultas</a></li>
              <li><a href="#equipa">Equipa</a></li>
              <li><a href="#programas">Programas</a></li>
            </ul>
          </div>
          <div>
            <h4>Legal</h4>
            <ul>
              <li><a href="/politica-privacidade">Política de Privacidade</a></li>
              <li><a href="https://www.livroreclamacoes.pt" rel="noopener" target="_blank">Livro de Reclamações Eletrónico</a></li>
              <li><a href="/termos">Termos dos Programas</a></li>
            </ul>
          </div>
        </div>
        <p class="footer__legal">
          A hipnoterapia é uma prática complementar de bem-estar e não substitui o diagnóstico,
          acompanhamento ou tratamento médico ou psicológico. Os resultados variam de pessoa para pessoa
          e nenhum resultado específico é garantido. Em caso de emergência, contacte o 112 (PT) ou o CVV 188 (BR).
          <br />© 2026 Hipnose Resolve · Site por BRANCT TECH
        </p>
      </div>
    </footer>

    <a class="wa-float" href="https://wa.me/351000000000" aria-label="Falar no WhatsApp" target="_blank" rel="noopener">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1l-.8 1c-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.3-2.9c-.2-.4.2-.4.5-1 .1-.2 0-.4 0-.5l-.8-1.8c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.9.9-1.2 2.1-.6 3.5.8 1.9 2.3 3.6 4.2 4.7 1.4.8 2.5 1 3.4.8.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2 0-.2-.2-.3-.8-.7Z"/></svg>
    </a>

    <script>
      // Reveals suaves — movimento que acalma, não que distrai
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }),
        { threshold: 0.14 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
