---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import fotoGab1 from '../assets/img/marta.jpeg';
import fotoGab2 from '../assets/img/tabaco.jpeg';
import fotoGab3 from '../assets/img/marta-nova.jpg';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalBusiness',
    name: 'Hipnose Resolve — Gabinete de Viseu',
    description: 'Gabinete de consultas presenciais da Hipnose Resolve em Viseu. Hipnoterapia e reprogramação mental, mediante marcação.',
    url: 'https://hipnoseresolve.pt/viseu',
    telephone: '+351915574759',
    address: { '@type': 'PostalAddress', streetAddress: 'Rua Dr. Álvaro Monteiro, 12 R/C dto.', postalCode: '3510-014', addressLocality: 'Viseu', addressCountry: 'PT' },
    hasMap: 'https://maps.google.com/?q=Rua+Dr.+%C3%81lvaro+Monteiro+12+Viseu',
  },
];
---
<Base
  title="Gabinete de Viseu — Consultas Presenciais · Hipnose Resolve"
  description="O gabinete da Hipnose Resolve em Viseu: um espaço acolhedor e discreto para as suas consultas presenciais de hipnoterapia. Rua Dr. Álvaro Monteiro, 12 — mediante marcação."
  schema={schema}
>
  <section class="wrap page-hero" style="padding-bottom: clamp(1.5rem, 3vw, 2.5rem);">
    <p class="eyebrow">Consultas presenciais · Viseu</p>
    <h1>O Gabinete de <em>Viseu</em></h1>
    <p class="lead">
      Um espaço acolhedor e discreto no coração de Viseu — pensado para se sentir
      em casa desde o primeiro minuto.
    </p>
  </section>

  <!-- MAPA + INFO (primeiro ecrã) -->
  <section class="wrap" style="padding-bottom: clamp(2.5rem, 5vw, 4rem);">
    <div class="gabinete__grid" style="margin-top:0;">
      <div class="reveal in">
        <div class="gabinete__mapa">
          <iframe
            src="https://www.google.com/maps?q=Rua+Dr.+%C3%81lvaro+Monteiro+12,+3510-014+Viseu,+Portugal&output=embed"
            width="100%" height="100%" style="border:0;"
            loading="eager" referrerpolicy="no-referrer-when-downgrade"
            title="Mapa — Gabinete Hipnose Resolve em Viseu"
          ></iframe>
        </div>
      </div>

      <div class="reveal in">
        <div class="gabinete__info">
          <div class="gabinete__linha">
            <span class="gabinete__rotulo">Morada</span>
            <p><b>Rua Dr. Álvaro Monteiro, 12 R/C dto.</b><br />3510-014 Viseu · Portugal</p>
          </div>
          <div class="gabinete__linha">
            <span class="gabinete__rotulo">Atendimento</span>
            <p>Consultas presenciais <b>mediante marcação</b> — com horários flexíveis, pensados também para quem trabalha.</p>
          </div>
          <div class="gabinete__linha">
            <span class="gabinete__rotulo">Contacto direto</span>
            <p><a href="tel:+351915574759">+351 915 574 759</a> · <a href="mailto:marcacoes@hipnoseresolve.pt">marcacoes@hipnoseresolve.pt</a></p>
          </div>
          <div style="display:flex; gap:.8rem; flex-wrap:wrap; margin-top:1.6rem;">
            <a class="btn btn--gold" href="https://wa.me/351915574759?text=Ol%C3%A1!%20Queria%20marcar%20uma%20consulta%20presencial%20em%20Viseu." target="_blank" rel="noopener">Marcar consulta presencial</a>
            <a class="btn btn--ghost" href="https://maps.google.com/?q=Rua+Dr.+%C3%81lvaro+Monteiro+12+Viseu" target="_blank" rel="noopener">Como chegar</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- O ESPAÇO -->
  <section class="section" style="background: var(--paper-deep); padding-block: clamp(3rem, 6vw, 5rem);">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow">O espaço</p>
        <h2>Onde a mudança <em>acontece</em></h2>
      </div>
      <div class="cards" style="margin-top:2.6rem;">
        <div class="photo-frame reveal" style="aspect-ratio: 4 / 5;"><Image src={fotoGab1} alt="O gabinete da Hipnose Resolve em Viseu" widths={[420, 700]} sizes="(max-width: 940px) 92vw, 30vw" /></div>
        <div class="photo-frame reveal" data-d="1" style="aspect-ratio: 4 / 5;"><Image src={fotoGab3} alt="A Dra. Marta Brito no gabinete de Viseu" widths={[420, 700]} sizes="(max-width: 940px) 92vw, 30vw" /></div>
        <div class="photo-frame reveal" data-d="2" style="aspect-ratio: 4 / 5;"><Image src={fotoGab2} alt="Espaço de consulta do gabinete de Viseu" widths={[420, 700]} sizes="(max-width: 940px) 92vw, 30vw" /></div>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA A PRESENCIAL -->
  <section class="wrap section">
    <div class="reveal" style="text-align:center;">
      <p class="eyebrow">Simples e sem burocracia</p>
      <h2>Como <em>funciona</em></h2>
    </div>
    <div class="steps" style="max-width: 980px; margin-inline: auto;">
      <div class="step reveal">
        <h3>Marca pelo WhatsApp</h3>
        <p>Escolhe a área e o dia — a nossa assistente responde a qualquer hora e confirma tudo.</p>
      </div>
      <div class="step reveal" data-d="1">
        <h3>Recebe a confirmação</h3>
        <p>Com a morada, as indicações e o lembrete automático antes da consulta.</p>
      </div>
      <div class="step reveal" data-d="2">
        <h3>É só chegar</h3>
        <p>Um espaço tranquilo, à porta fechada, com todo o tempo dedicado a si.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top:0;">
    <div class="cta-final reveal">
      <div class="cta-final__grid">
        <div style="text-align:left; max-width: 52ch;">
          <h2 style="margin-inline:0;">Prefere falar <em>pessoalmente</em>?</h2>
          <div style="display:flex; gap:.9rem; flex-wrap:wrap; margin-top:2rem;">
            <a class="btn btn--gold" href="https://wa.me/351915574759?text=Ol%C3%A1!%20Queria%20marcar%20uma%20consulta%20presencial%20em%20Viseu." target="_blank" rel="noopener">Marcar em Viseu</a>
            <a class="btn btn--ghost" href="/consultas">Prefiro online</a>
          </div>
        </div>
        <div class="selo" aria-hidden="true">Acreditamos em si, mesmo antes de voltar a acreditar em si próprio.</div>
      </div>
    </div>
  </section>
</Base>
