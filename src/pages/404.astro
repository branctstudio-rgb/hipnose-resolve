---
import Base from '../layouts/Base.astro';
---
<Base
  title="Página não encontrada — Hipnose Resolve"
  description="A página que procura não existe. Respire — e volte ao início."
>
  <section class="login-wrap wrap" style="text-align:center;">
    <div>
      <p class="eyebrow" style="justify-content:center; display:flex;">404</p>
      <h1 style="font-size: clamp(2.2rem, 5vw, 3.6rem);">Esta página <em>não existe</em>.</h1>
      <p class="lead" style="margin:1.4rem auto 2.4rem;">
        Respire fundo — acontece. O caminho de volta está aqui.
      </p>
      <div style="display:flex; gap:.9rem; justify-content:center; flex-wrap:wrap;">
        <a class="btn btn--primary" href="/">Voltar ao início</a>
        <a class="btn btn--ghost" href="/areas">Ver áreas de intervenção</a>
      </div>
    </div>
  </section>
</Base>
