---
import Base from '../layouts/Base.astro';
import { WA_URL } from '../config/site';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import fotoMartaNova from '../assets/img/marta-nova.jpg';
import areaEmagrecimento from '../assets/img/area-emagrecimento.jpg';
import areaAutoestima from '../assets/img/area-autoestima.jpg';
import areaRespirar from '../assets/img/area-respirar.jpg';
import martaTransforma from '../assets/img/marta-transforma.jpg';
import martaRosto from '../assets/img/marta-rosto.jpg';
import percursoCliente from '../assets/img/percurso-cliente.jpg';
import martaBlazer from '../assets/img/marta-blazer.jpg';
import fotoCatia from '../assets/img/catia.jpg';
import blogPoltrona from '../assets/img/blog-a.jpg';
import blogJanela from '../assets/img/blog-b.jpg';
import blogFruta from '../assets/img/blog-c.jpg';
import logoFecho from '../assets/img/logo-novo-simbolo.png';
const fotoDoPost = (titulo: string) =>
  /hipnoterapia/i.test(titulo) ? blogPoltrona : /ansiedade/i.test(titulo) ? blogJanela : blogFruta;
import fotoMagra from '../assets/img/magramente-1.jpg';
import fotoTabaco from '../assets/img/tabaco.jpeg';
import fotoAnsiedade from '../assets/img/ansiedade.png';
import fotoRelacoes from '../assets/img/relacionamentos.jpg';
import fotoStress from '../assets/img/stress.webp';
import fotoMedos from '../assets/img/medos.jpg';

const programas = (await getCollection('programas')).sort((a, b) => a.data.ordem - b.data.ordem);
const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.data).getTime() - new Date(a.data.data).getTime())
  .slice(0, 3);
const fmtData = (d: string) => new Date(d).toLocaleDateString('pt-PT', { day: 'numeric', month: 'long', year: 'numeric' });

const ico = {
  pessoa: 'M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 8c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5',
  estrela: 'M12 3.5l2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4L4.2 9.2l5.4-.8L12 3.5Z',
  coracao: 'M12 20s-7-4.5-9-9c-1.2-2.8.5-6 3.6-6 1.9 0 3.4 1 4.4 2.6C12 6 13.5 5 15.4 5c3.1 0 4.8 3.2 3.6 6-2 4.5-7 9-7 9Z',
  chave: 'M12 12a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 0v9m0-5.5h3.5M12 21h2.5',
  globo: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm-9-9h18M12 3c2.5 2.4 4 5.6 4 9s-1.5 6.6-4 9c-2.5-2.4-4-5.6-4-9s1.5-6.6 4-9Z',
};
const Icon = (d: string) => `<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${d}" stroke="currentColor"/></svg>`;

const faq = [
  { q: 'A hipnose é segura? Vou perder o controlo?', a: 'Sim, é segura — e não, nunca perde o controlo. Em hipnoterapia clínica está sempre consciente e no comando; a terapeuta apenas guia um estado de foco profundo, semelhante ao de estar absorto num bom livro.' },
  { q: 'As sessões online funcionam tão bem como as presenciais?', a: 'Sim. Basta um lugar tranquilo, auscultadores e ligação estável. O link da sessão chega automaticamente com a confirmação.' },
  { q: 'Qual a diferença entre a Consulta de Avaliação e a de Tratamento?', a: 'A Avaliação (2h) é o ponto de partida: conhecer a sua história e definir o plano. As consultas de Tratamento (1h) são o acompanhamento contínuo desse plano.' },
  { q: 'A hipnoterapia substitui o médico ou psicólogo?', a: 'Não. É uma prática complementar de bem-estar e não substitui diagnóstico nem tratamento médico ou psicológico.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalBusiness',
    name: 'Hipnose Resolve',
    description: 'Clínica de Reprogramação Mental — reprogramamos mentes e comportamentos. Consultas online e presenciais, Portugal e Brasil.',
    url: 'https://hipnoseresolve.pt',
    telephone: '+351915574759',
    email: 'info@hipnoseresolve.pt',
    address: { '@type': 'PostalAddress', streetAddress: 'Rua Dr. Álvaro Monteiro, 12 R/C dto.', postalCode: '3510-014', addressLocality: 'Viseu', addressCountry: 'PT' },
    founder: { '@type': 'Person', name: 'Marta Brito', jobTitle: 'Hipnoterapeuta' },
    sameAs: ['https://www.instagram.com/hipnoseresolve/', 'https://www.facebook.com/profile.php?id=61555999870032'],
    areaServed: ['PT', 'BR'],
    availableLanguage: 'pt',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Base
  title="Hipnose Resolve — Clínica de Reprogramação Mental · Online e Presencial"
  description="Reprogramamos mentes e comportamentos. Transformamos vidas. Hipnose clínica para ansiedade, hábitos, emagrecimento e cessação tabágica — online e presencial, Portugal e Brasil."
  schema={schema}
>
  <!-- HERO — minimal, o vídeo fala -->
  <section class="hero-open">
    <div class="hero-open__video" aria-hidden="true">
      <video autoplay muted loop playsinline preload="metadata" poster="/media/hero-bemestar-poster.jpg" data-ambiente>
        <source src="/media/hero-bemestar.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero-open__veil" aria-hidden="true"></div>
    <div class="wrap">
      <div class="hero-open__conteudo">
        <p class="eyebrow" data-rise="1">Online em Portugal e Brasil · Presencial em Viseu</p>
        <h1 data-rise="2">Reprogramamos mentes.<br /><em>Transformamos vidas.</em></h1>
        <p class="sr-only">
          Hipnoterapia personalizada para ansiedade, hábitos, emagrecimento e cessação
          tabágica — online em Portugal e no Brasil ou presencialmente em Viseu.
        </p>
        <div class="hero__cta" data-rise="3">
          <a class="btn btn--gold" href="/consultas">
            Marcar avaliação
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8h11m0 0L9 4m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a class="btn btn--ghost" href={WA_URL} target="_blank" rel="noopener noreferrer">Falar com a equipa</a>
        </div>
        <p data-rise="3" style="margin-top: 1.1rem; font-size: .8rem; color: var(--ink-soft); letter-spacing: .02em;">
          Atendimento personalizado · Ambiente confidencial · Online e presencial
        </p>
      </div>
    </div>
    <div class="hero-open__rodape" data-rise="4">
      <a class="acesso" href="/consultas">
        <Fragment set:html={Icon(ico.globo)} />
        <span><b>Clínica Online</b><span>Portugal e Brasil</span></span>
      </a>
      <a class="acesso" href="/viseu">
        <Fragment set:html={Icon(ico.pessoa)} />
        <span><b>Gabinete de Viseu</b><span>localização e horário</span></span>
      </a>
      <a class="acesso" href="/membros">
        <Fragment set:html={Icon(ico.chave)} />
        <span><b>Área de Membros</b><span>os seus conteúdos exclusivos</span></span>
      </a>
    </div>
  </section>

  <!-- MANIFESTO (curto) -->
  <section class="manifesto" aria-label="A nossa missão">
    <div class="wrap">
      <p class="manifesto__txt">
        {'Como se sente hoje? Seja qual for a resposta — há caminho.'.split(' ').map((w) => <span class="w">{w} </span>)}
        <em>{'Ao seu ritmo, sem julgamento.'.split(' ').map((w) => <span class="w">{w} </span>)}</em>
      </p>
    </div>
  </section>

  <!-- PORQUÊ (3 cartões ricos) -->
  <section class="section">
    <div class="wrap" style="text-align:center;">
      <p class="eyebrow">Porquê a Hipnose Resolve?</p>
      <h2>Especialistas em <em>Reprogramação Mental</em></h2>
      <div class="why-cards">
        <div class="why-card why-card--gold reveal">
          <span class="num" aria-hidden="true">01</span>
          <Fragment set:html={Icon(ico.pessoa)} />
          <h3>100% personalizado</h3>
          <p>Cada plano é desenhado para a sua história — nunca o contrário.</p>
        </div>
        <div class="why-card why-card--mist reveal" data-d="1">
          <span class="num" aria-hidden="true">02</span>
          <Fragment set:html={Icon(ico.estrela)} />
          <h3>Abordagem especializada</h3>
          <p>Hipnoterapia orientada para mudanças conscientes e consistentes.</p>
        </div>
        <div class="why-card why-card--ink reveal" data-d="2">
          <span class="num" aria-hidden="true">03</span>
          <Fragment set:html={Icon(ico.coracao)} />
          <h3>Sempre consigo</h3>
          <p>Antes, durante e depois — num espaço seguro e sem julgamentos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ÁREAS DE TRANSFORMAÇÃO (5 principais + 10 complementares) -->
  <section class="section areas-trans" id="terapias">
    <div class="wrap">
      <div class="areas-trans__linha1">
        <div class="areas-trans__intro reveal">
          <p class="eyebrow">Áreas em que podemos ajudar</p>
          <h2>Um acompanhamento para cada momento da <em>sua vida</em>.</h2>
          <p>Da ansiedade à mudança de hábitos, cada percurso é pensado para a sua história, os seus objetivos e o momento que está a viver.</p>
          <p class="areas-trans__conta"><span aria-hidden="true">✦</span> 15 áreas de acompanhamento</p>
          <a class="btn btn--ghost" href="/areas">Conhecer todas as terapias</a>
        </div>
        <a class="area-card reveal" data-d="1" href="/areas/ansiedade-panico">
          <Image src={blogJanela} alt="" widths={[600, 1000]} sizes="(max-width: 768px) 92vw, 34vw" />
          <div class="area-card__txt">
            <span>Ansiedade e Pânico</span>
            <h3>Ansiedade e Pânico</h3>
            <p>Quando a mente não desliga e o corpo vive em alerta.</p>
          </div>
          <i class="area-card__seta" aria-hidden="true">→</i>
        </a>
        <a class="area-card reveal" data-d="2" href="/areas/emagrecimento">
          <Image src={blogFruta} alt="" widths={[600, 1000]} sizes="(max-width: 768px) 92vw, 34vw" />
          <div class="area-card__txt">
            <span>Emagrecimento</span>
            <h3>Emagrecimento</h3>
            <p>Mudar a relação com a comida — não mais uma dieta.</p>
          </div>
          <i class="area-card__seta" aria-hidden="true">→</i>
        </a>
      </div>
      <div class="areas-trans__linha2">
        <a class="area-card reveal" href="/areas/cessacao-tabagica">
          <Image src={areaRespirar} alt="" widths={[600, 1000]} sizes="(max-width: 768px) 92vw, 30vw" />
          <div class="area-card__txt">
            <span>Cessação Tabágica</span>
            <h3>Cessação Tabágica</h3>
            <p>Deixar de fumar sem sentir que perde algo.</p>
          </div>
          <i class="area-card__seta" aria-hidden="true">→</i>
        </a>
        <a class="area-card reveal" data-d="1" href="/areas/stress-burnout">
          <Image src={blogPoltrona} alt="" widths={[600, 1000]} sizes="(max-width: 768px) 92vw, 30vw" />
          <div class="area-card__txt">
            <span>Stress e Burnout</span>
            <h3>Stress e Burnout</h3>
            <p>Recuperar energia e limites antes do corpo os exigir.</p>
          </div>
          <i class="area-card__seta" aria-hidden="true">→</i>
        </a>
        <a class="area-card area-card--espresso reveal" data-d="2" href="/areas/autoestima-empoderamento">
          <div class="area-card__txt">
            <span>Autoestima e Empoderamento</span>
            <h3>Autoestima e Empoderamento</h3>
            <p>Silenciar o crítico interno e voltar a ocupar o seu lugar.</p>
          </div>
          <i class="area-card__seta" aria-hidden="true">→</i>
        </a>
      </div>
      <div class="areas-trans__mais reveal">
        <h3 class="areas-trans__mais-titulo">Também podemos ajudar</h3>
        <div class="areas-trans__lista">
          {[
            ['Medos e Fobias', 'medos-fobias'],
            ['Fertilidade, Parto e Pós-parto', 'fertilidade-parto-pos-parto'],
            ['Trauma', 'trauma'],
            ['Luto', 'luto'],
            ['Mudança de Hábitos', 'mudanca-habitos'],
            ['Relacionamentos e Sexualidade', 'relacionamentos-sexualidade'],
            ['Vícios', 'vicios'],
            ['Hipnoterapia Infantil', 'infantil'],
            ['Vidas Passadas', 'vidas-passadas'],
            ['Depressão', 'depressao'],
          ].map(([nome, slug]) => (
            <a class="area-item" href={`/areas/${slug}`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l2.2 6.8L21 12l-6.8 2.2L12 21l-2.2-6.8L3 12l6.8-2.2L12 3Z"/></svg>
              <span>{nome}</span>
              <i aria-hidden="true">→</i>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
  <!-- PROGRAMAS — Coleção de Transformação (vitrine editorial) -->
  <section class="section" id="programas" style="background: var(--paper-deep); padding-block: clamp(3.5rem, 7vw, 5.5rem);">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow">Programas de transformação</p>
        <h2>Três caminhos. Uma transformação <em>verdadeiramente sua</em>.</h2>
        <p class="lead" style="max-width: 52ch; margin-inline: auto; margin-top: 1.1rem;">
          Escolha o percurso que mais se aproxima do momento que está a viver. Cada programa
          combina acompanhamento, ferramentas práticas e uma abordagem personalizada.
        </p>
      </div>
      <div class="colecao reveal" data-d="1">
        <a class="colecao__item colecao__magra" href="/programas/transforma-te">
          <div class="colecao__img" aria-hidden="true">
            <Image src={martaTransforma} alt="" widths={[700, 1100]} sizes="(max-width: 980px) 92vw, 50vw" />
          </div>
          <div class="colecao__body">
            <span class="colecao__cat">Programa Mente e Corpo</span>
            <h3>TRANSFORMA-TE</h3>
            <p>Oito semanas para trabalhar hábitos, movimento e equilíbrio de forma integrada.</p>
            <ul class="colecao__meta">
              <li>Mente e corpo, em conjunto</li>
              <li>Acompanhamento próximo</li>
              <li>Online</li>
            </ul>
            <span class="colecao__cta">Explorar o programa <i aria-hidden="true">→</i></span>
          </div>
        </a>
        <a class="colecao__item colecao__tt" href="/programas/magramente">
          <span class="colecao__cat">Programa de Emagrecimento</span>
          <h3>MagraMente</h3>
          <p>Uma mudança que começa na mente e se reflete na forma como vive o seu corpo e a alimentação.</p>
          <span class="colecao__cta">Descobrir o MagraMente <i aria-hidden="true">→</i></span>
        </a>
        <a class="colecao__item colecao__syf" href="/programas/set-you-free">
          <span class="colecao__cat">Cessação Tabágica</span>
          <h3>Set You Free</h3>
          <p>Um percurso direcionado para quem decidiu deixar de fumar e recuperar a liberdade de escolha.</p>
          <span class="colecao__cta">Conhecer o programa <i aria-hidden="true">→</i></span>
        </a>
      </div>
    </div>
  </section>


  <!-- O SEU PERCURSO (foto editorial + acordeão acessível) -->
  <section class="section" id="percurso" style="padding-block: clamp(3.5rem, 7vw, 5.5rem);">
    <div class="wrap">
      <div class="reveal" style="text-align:center; max-width: 62ch; margin-inline: auto;">
        <p class="eyebrow">Simples de começar</p>
        <h2>Um percurso claro, <em>construído consigo</em>.</h2>
        <p class="lead" style="margin-top:1rem; margin-inline:auto;">
          Desde o primeiro contacto, cada etapa é pensada para que se sinta informada,
          segura e acompanhada.
        </p>
      </div>
      <div class="percurso__grid">
        <figure class="percurso__foto reveal">
          <Image src={percursoCliente} alt="Consulta de hipnoterapia — uma cliente a sentir-se ouvida num ambiente acolhedor" widths={[700, 1200]} sizes="(max-width: 940px) 92vw, 40vw" />
          <figcaption>Um acompanhamento próximo, ao seu ritmo.</figcaption>
        </figure>
        <div class="percurso__passos reveal" data-d="1">
          <details class="passo" name="percurso" open>
            <summary>
              <span class="passo__num" aria-hidden="true">01</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a8 8 0 0 1-11.6 7.2L4 21l1.8-5.4A8 8 0 1 1 21 12Z"/></svg>
              <span class="passo__titulo">Primeiro contacto</span>
              <span class="passo__mais" aria-hidden="true">+</span>
            </summary>
            <p>Conte-nos o que procura e esclareça as suas primeiras dúvidas. A nossa equipa está disponível para orientar este primeiro passo com clareza e tranquilidade.</p>
          </details>
          <details class="passo" name="percurso">
            <summary>
              <span class="passo__num" aria-hidden="true">02</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5 9c0-2.8 2.2-5 5-5s5 2.2 5 5M16 8a3 3 0 0 1 3 3m2 9c0-2.2-1.3-4-3.2-4.6"/></svg>
              <span class="passo__titulo">Consulta de avaliação</span>
              <span class="passo__mais" aria-hidden="true">+</span>
            </summary>
            <p>Conhecemos a sua história, os seus objetivos e o momento que está a viver, num ambiente confidencial e livre de julgamentos.</p>
          </details>
          <details class="passo" name="percurso">
            <summary>
              <span class="passo__num" aria-hidden="true">03</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 21c6-2 2-9 8-11m0 0c2.5-1 5-3 6-7-4 1-6 3.5-7 6m1 1-1-1"/></svg>
              <span class="passo__titulo">Plano personalizado</span>
              <span class="passo__mais" aria-hidden="true">+</span>
            </summary>
            <p>Definimos consigo o percurso mais adequado às suas necessidades, respeitando o seu ritmo e os seus objetivos.</p>
          </details>
          <details class="passo" name="percurso">
            <summary>
              <span class="passo__num" aria-hidden="true">04</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-4.5-9-9c-1.2-2.8.5-6 3.6-6 1.9 0 3.4 1 4.4 2.6C12 7 13.5 6 15.4 6c3.1 0 4.8 3.2 3.6 6-2 4.5-7 9-7 9Z"/></svg>
              <span class="passo__titulo">Acompanhamento</span>
              <span class="passo__mais" aria-hidden="true">+</span>
            </summary>
            <p>Caminhamos consigo durante todo o processo, com proximidade, orientação e espaço para acompanhar a sua evolução.</p>
          </details>
          <div class="percurso__cta">
            <a class="btn btn--gold" href="/consultas">Marcar consulta de avaliação</a>
            <a class="percurso__link" href={WA_URL} target="_blank" rel="noopener noreferrer">Falar com a equipa</a>
            <p>Online em Portugal e no Brasil · Presencial em Viseu</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FUNDADORA (grid: foto retangular grande à esquerda, texto à direita) -->
  <section class="section" style="background: var(--paper-deep); padding-block: clamp(3.5rem, 7vw, 5.5rem);">
    <div class="wrap fundadora-split">
    <div class="fundadora-split__foto reveal in">
      <Image src={martaRosto} alt="Dra. Marta Brito, fundadora da Hipnose Resolve" widths={[700, 1086]} sizes="(max-width: 940px) 92vw, 46vw" />
    </div>
    <div class="fundadora-split__txt">
      <div class="reveal" data-d="1">
        <p style="font-weight:600; color:var(--ink-soft); font-size:.98rem; margin-bottom:.5rem;">Dra. Marta Brito</p>
        <h2 style="font-size: clamp(1.9rem, 3.2vw, 2.6rem); text-transform:none; letter-spacing:-.01em; color:#92612a;">Fundadora e Hipnoterapeuta</h2>
        <p style="margin-top:1.2rem; max-width:48ch;">
          Hipnoterapeuta, a estudar a mente humana desde 2000. Especialista em emagrecimento
          e cessação tabágica.
        </p>
        <p style="margin-top:.9rem; max-width:48ch;">
          Acompanho cada pessoa de forma próxima e personalizada — online, em Portugal
          e no Brasil, ou presencialmente no gabinete de Viseu.
        </p>
        <p style="margin-top:1.2rem; font-family:var(--serif); font-style:italic; font-size:1.25rem; color:#92612a;">
          "Estou aqui para caminhar consigo."
        </p>
        <div style="display:flex; gap:.9rem; flex-wrap:wrap; margin-top:1.8rem;">
          <a class="btn btn--gold" href="/equipa">Sobre a Dra. Marta</a>
          <a class="btn btn--ghost" href="/consultas">Marcar avaliação</a>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- A NOSSA EQUIPA (cards de especialistas) -->
  <section class="section" id="equipa" style="padding-block: clamp(3.5rem, 7vw, 5.5rem);">
    <div class="wrap">
      <div class="equipa__topo reveal">
        <div>
          <p class="eyebrow">Quem a acompanha</p>
          <h2>A nossa equipa de <em>especialistas</em></h2>
        </div>
        <a class="percurso__link" href="/equipa">Conhecer a equipa →</a>
      </div>
      <div class="equipa__grid">
        <a class="equipa-card reveal" href="/equipa">
          <div class="equipa-card__foto">
            <Image src={martaBlazer} alt="Dra. Marta Brito" widths={[420, 700]} sizes="(max-width: 700px) 92vw, 24vw" />
            <span class="equipa-card__seta" aria-hidden="true">↗</span>
          </div>
          <div class="equipa-card__info">
            <h3>Dra. Marta Brito</h3>
            <span>Hipnoterapeuta · Fundadora</span>
            <p>Emagrecimento e cessação tabágica — a estudar a mente humana desde 2000.</p>
          </div>
        </a>
        <a class="equipa-card reveal" data-d="1" href="/equipa">
          <div class="equipa-card__foto">
            <Image src={fotoCatia} alt="Dra. Cátia Fena" widths={[420, 700]} sizes="(max-width: 700px) 92vw, 24vw" />
            <span class="equipa-card__seta" aria-hidden="true">↗</span>
          </div>
          <div class="equipa-card__info">
            <h3>Dra. Cátia Fena</h3>
            <span>Hipnoterapeuta · Trauma e Vícios</span>
            <p>Profundidade e um espaço seguro para fazer as pazes com a sua história.</p>
          </div>
        </a>
        <a class="equipa-card reveal" data-d="2" href="/equipa">
          <div class="equipa-card__foto equipa-card__foto--breve"><b aria-hidden="true">M</b></div>
          <div class="equipa-card__info">
            <h3>Margarida Ferreira</h3>
            <span>Hipnoterapeuta · Vidas Passadas</span>
            <p>Terapia regressiva e de Vidas Passadas. Junta-se em breve à equipa.</p>
          </div>
        </a>
        <a class="equipa-card reveal" data-d="3" href="/equipa">
          <div class="equipa-card__foto equipa-card__foto--breve"><b aria-hidden="true">M</b></div>
          <div class="equipa-card__info">
            <h3>Marlene</h3>
            <span>Hipnoterapeuta · Infantil</span>
            <p>Hipnoterapia infantil. Junta-se em breve à equipa.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- TESTEMUNHOS (banda escura) -->
  <section class="depo-band" id="testemunhos">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow">Histórias reais</p>
        <h2>O que dizem <em>sobre nós</em></h2>
      </div>
      <div class="quotes__grid">
        <div class="quote quote--metric reveal">
          <b>−20 kg</b>
          <span>a experiência da Maria no programa MagraMente</span>
        </div>
        <blockquote class="quote quote--destaque reveal" data-d="1">
          <p>Três anos de dietas sem resultado. Com a Marta perdi 20 kg — mudei por dentro, e o resto seguiu.</p>
          <footer><span class="quote__avatar" aria-hidden="true">MF</span><span><b>Maria Ferreira</b><br /><span style="font-size:.82rem;">Programa MagraMente</span></span></footer>
        </blockquote>
        <blockquote class="quote reveal" data-d="2">
          <p>Fumei durante 30 anos. Numa sessão de 90 minutos, saí de lá não fumador — e assim fiquei.</p>
          <footer><span class="quote__avatar" aria-hidden="true">JP</span><span><b>J. Paulo Guerreiro</b><br /><span style="font-size:.82rem;">Set You Free</span></span></footer>
        </blockquote>
        <blockquote class="quote reveal" data-d="3">
          <p>Perdi 10 kg em dois meses, inteiramente online. Senti-me acompanhada como se estivesse na sala ao lado.</p>
          <footer><span class="quote__avatar" aria-hidden="true">C</span><span><b>Carine</b><br /><span style="font-size:.82rem;">MagraMente online</span></span></footer>
        </blockquote>
      </div>
      <p class="reveal" style="text-align:center; margin-top:1.8rem; font-size:.78rem; color: rgba(247, 232, 210, .65);">
        Os testemunhos representam experiências individuais. Os resultados podem variar.
      </p>
    </div>
  </section>

  <!-- BLOG (últimos artigos) -->
  <section class="section" id="blog" style="padding-block: clamp(3.5rem, 7vw, 5.5rem);">
    <div class="wrap">
      <div class="equipa__topo reveal">
        <div>
          <p class="eyebrow">Do nosso blog</p>
          <h2>Ler também <em>transforma</em></h2>
        </div>
        <a class="percurso__link" href="/blog">Ver todos os artigos →</a>
      </div>
      <div class="cards" style="margin-top: 2.6rem;">
        {posts.map((p, i) => (
          <a class="card-l reveal" data-d={String(i)} href={`/blog/${p.id}`}>
            <div class="card-l__img">
              <Image src={fotoDoPost(p.data.titulo)} alt="" widths={[480, 760]} sizes="(max-width: 940px) 92vw, 30vw" />
            </div>
            <span class="meta">{fmtData(p.data.data)} · {p.data.categoria}</span>
            <h3>{p.data.titulo}</h3>
            <p>{p.data.resumo}</p>
            <span class="mais">Ler artigo →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ (split com cartão de contacto) -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow">Perguntas frequentes</p>
        <h2>Antes de <em>dar o passo</em></h2>
      </div>
      <div class="faq-split">
        <div class="faq-card reveal">
          <span class="monogram" aria-hidden="true" style="margin-inline:auto;">HR</span>
          <h3>Ainda tem dúvidas?</h3>
          <p>A nossa assistente responde no WhatsApp — a qualquer hora, com humanidade.</p>
          <a class="btn btn--primary" href={WA_URL} target="_blank" rel="noopener" style="width:100%; justify-content:center;">Falar no WhatsApp</a>
        </div>
        <div class="faq reveal" data-d="1">
          {faq.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL (fecho editorial premium) -->
  <section class="section" style="padding-top:0;">
    <div class="cta-final cta-fecho reveal">
      <Image src={logoFecho} alt="" widths={[120]} sizes="56px" class="cta-fecho__simbolo" />
      <p class="cta-fecho__marca">Hipnose Resolve</p>
      <h2>Não precisa de ter tudo resolvido<br />para dar <em>o primeiro passo</em>.</h2>
      <p class="cta-fecho__sub">Fale connosco e descubra qual poderá ser o percurso mais adequado para si.</p>
      <div class="cta-fecho__botoes">
        <a class="btn btn--gold" href="/consultas">Marcar consulta de avaliação</a>
        <a class="btn btn--ghost" href={WA_URL} target="_blank" rel="noopener noreferrer">Falar com a equipa</a>
      </div>
      <div class="cta-fecho__linha" aria-hidden="true"></div>
      <p class="cta-fecho__info">Online em Portugal e Brasil · Presencial em Viseu · Atendimento confidencial</p>
    </div>
  </section>
</Base>
