---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import fotoMarta from '../assets/img/marta.jpeg';
import fotoMarta3 from '../assets/img/marta-3.png';
import fotoMagra from '../assets/img/magramente-1.jpg';
import fotoTabaco from '../assets/img/tabaco.jpeg';

const areas = (await getCollection('areas')).sort((a, b) => a.data.ordem - b.data.ordem);
const programas = (await getCollection('programas')).sort((a, b) => a.data.ordem - b.data.ordem);
const areaNome = (id: string) => areas.find((a) => a.id === id)?.data.nome ?? '';

const faq = [
  {
    q: 'A hipnose é segura? Vou perder o controlo?',
    a: 'Sim, é segura — e não, nunca perde o controlo. Em hipnoterapia clínica está sempre consciente e no comando; a terapeuta apenas guia um estado de foco profundo, semelhante ao de estar absorto num bom livro.',
  },
  {
    q: 'As consultas online funcionam tão bem como as presenciais?',
    a: 'Sim. A hipnoterapia adapta-se muito bem ao formato online: basta um lugar tranquilo, auscultadores e ligação estável. O link da sessão chega automaticamente com a confirmação.',
  },
  {
    q: 'Qual a diferença entre a Consulta de Avaliação e a de Tratamento?',
    a: 'A Avaliação (2h) é o ponto de partida: conhecer a sua história e definir o plano. As consultas de Tratamento (1h) são as sessões de acompanhamento contínuo desse plano.',
  },
  {
    q: 'A hipnoterapia substitui o médico ou psicólogo?',
    a: 'Não. É uma prática complementar de bem-estar e não substitui diagnóstico nem tratamento médico ou psicológico. Sempre que necessário, trabalhamos em articulação com outros profissionais de saúde.',
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalBusiness',
    name: 'Hipnose Resolve',
    description: 'Clínica de hipnoterapia — consultas online e presenciais, Portugal e Brasil, em português.',
    url: 'https://hipnoseresolve.pt',
    telephone: '+351915574759',
    email: 'info@hipnoseresolve.pt',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Rua Dr. Álvaro Monteiro, 12 R/C dto.',
      postalCode: '3510-014',
      addressLocality: 'Viseu',
      addressCountry: 'PT',
    },
    founder: { '@type': 'Person', name: 'Marta Brito', jobTitle: 'Hipnoterapeuta' },
    sameAs: [
      'https://www.instagram.com/hipnoseresolve/',
      'https://www.facebook.com/profile.php?id=61555999870032',
    ],
    areaServed: ['PT', 'BR'],
    availableLanguage: 'pt',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Base
  title="Hipnose Resolve — Clínica de Hipnoterapia · Online e Presencial"
  description="Hipnoterapia clínica para ansiedade, medos, hábitos, emagrecimento e mais. Consultas online e presenciais, em português — Portugal e Brasil. Marque a sua Consulta de Avaliação."
  schema={schema}
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero__grid">
      <div>
        <p class="eyebrow" data-rise="1">Clínica de Hipnoterapia · Online e Presencial</p>
        <h1 data-rise="2">A mudança que procura já vive <em>dentro de si</em>.</h1>
        <p class="lead" data-rise="3">
          Hipnoterapia clínica para ansiedade, medos, hábitos e muito mais.
          Acompanhamento humano, em português — esteja em Portugal ou no Brasil.
        </p>
        <div class="hero__cta" data-rise="4">
          <a class="btn btn--primary" href="/consultas">
            Marcar Consulta de Avaliação
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8h11m0 0L9 4m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a class="btn btn--ghost" href="/programas">Conhecer os programas</a>
        </div>
        <div class="hero__proof" data-rise="5">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span>Sessões online com link automático</span>
          <span aria-hidden="true">·</span>
          <span>Respostas no WhatsApp a qualquer hora</span>
        </div>
      </div>
      <div style="position:relative;" data-rise="3">
        <div class="arch arch--img">
          <Image src={fotoMarta} alt="Marta Brito, hipnoterapeuta e fundadora da Hipnose Resolve, no consultório" widths={[480, 800, 1100]} sizes="(max-width: 940px) 92vw, 44vw" loading="eager" />
        </div>
        <div class="chip-float" style="top:9%; left:-4%;">
          <span class="dot"></span> Consulta confirmada — link Meet enviado
        </div>
        <div class="chip-float" style="bottom:14%; right:-3%;">
          🌿 Online e presencial
        </div>
      </div>
    </div>
  </section>

  <!-- FITA DE ÁREAS -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__track">
      {[...areas, ...areas].map((a) => <span>{a.data.nome}</span>)}
    </div>
  </div>

  <!-- EMPATIA -->
  <section class="section empathy">
    <div class="wrap reveal">
      <p class="eyebrow" style="justify-content:center; display:flex;">É bem-vinda. É bem-vindo.</p>
      <p>Se chegou até aqui às onze da noite, de coração apertado — <em>há caminho</em>. E não o vai percorrer sozinho.</p>
    </div>
  </section>

  <!-- ESPECIALIDADES DA MARTA (foco) -->
  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">As especialidades da Marta Brito</p>
        <h2>Dois caminhos, <em>uma missão</em></h2>
        <p class="lead" style="margin-top:1.2rem;">
          Emagrecer sem guerra com a comida. Deixar de fumar sem sentir que perde algo.
          São as duas grandes especialidades da fundadora — cada uma com o seu programa.
        </p>
      </div>
      <div class="spec">
        <a class="spec-card reveal" href="/programas/magramente">
          <Image src={fotoMagra} alt="Marta Brito em consulta online do programa MagraMente" widths={[600, 900]} sizes="(max-width: 880px) 92vw, 46vw" />
          <div class="spec-card__body">
            <span class="kicker">Emagrecimento · Programa MagraMente</span>
            <h3>Emagreça de dentro para fora</h3>
            <p>Hipnose para eliminar a fome emocional e mudar a relação com a comida. Protocolos de 4, 6 ou 12 terapias.</p>
            <span class="mais">Conhecer o MagraMente →</span>
          </div>
        </a>
        <a class="spec-card reveal" data-d="1" href="/programas/set-you-free">
          <Image src={fotoTabaco} alt="Marta Brito numa sessão de cessação tabágica" widths={[600, 900]} sizes="(max-width: 880px) 92vw, 46vw" />
          <div class="spec-card__body">
            <span class="kicker">Cessação Tabágica · Programa Set You Free</span>
            <h3>Deixe de fumar numa sessão</h3>
            <p>Hipnose, PNL e coaching para desinstalar o hábito — com 30 dias de acompanhamento.</p>
            <span class="mais">Conhecer o Set You Free →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ÁREAS -->
  <section class="section areas" id="areas">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Áreas de intervenção</p>
        <h2>Onde a hipnoterapia<br />pode <em>ajudar</em></h2>
      </div>
      <div class="areas__grid reveal" data-d="1">
        {areas.map((a) => (
          <a class="area" href={`/areas/${a.id}`}>
            <h3>{a.data.nome}</h3>
            <p>{a.data.curto}</p>
          </a>
        ))}
        <a class="area area--cta" href="/contactos">
          <h3>Não sabe por onde começar?</h3>
          <p>Fale connosco — ajudamos a encontrar a terapeuta e o caminho certos para si.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CONSULTAS / COMO FUNCIONA -->
  <section class="section" id="consultas">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Consultas</p>
        <h2>Como <em>funciona</em></h2>
        <p class="lead" style="margin-top:1.2rem;">Sem formulários que não marcam nada: escolhe, agenda e recebe a confirmação com tudo o que precisa.</p>
      </div>
      <div class="steps">
        <div class="step reveal" data-d="1">
          <h3>Consulta de Avaliação</h3>
          <p>Duas horas para si: a sua história, os seus objetivos e um plano claro de acompanhamento, desenhado consigo.</p>
          <span class="tag">2 horas · online ou presencial</span>
        </div>
        <div class="step reveal" data-d="2">
          <h3>Plano personalizado</h3>
          <p>Sessões, programas ou ambos — cada percurso é único, com a terapeuta certa para a sua área.</p>
          <span class="tag">à sua medida</span>
        </div>
        <div class="step reveal" data-d="3">
          <h3>Consultas de Tratamento</h3>
          <p>Sessões de uma hora, com continuidade e lembretes automáticos. Se for online, o link chega no email.</p>
          <span class="tag">1 hora · lembretes incluídos</span>
        </div>
      </div>
      <div class="flow reveal" data-d="2" aria-label="Passos da marcação online">
        <div class="flow__step"><i>1</i><span>Escolhe a área</span></div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step"><i>2</i><span>Escolhe a terapeuta</span></div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step"><i>3</i><span>Online ou presencial</span></div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step"><i>4</i><span>Escolhe o horário</span></div>
        <span class="flow__arrow" aria-hidden="true">→</span>
        <div class="flow__step"><i>5</i><span>Confirmado — Meet no email ✓</span></div>
      </div>
    </div>
  </section>

  <!-- EQUIPA -->
  <section class="section" id="equipa" style="background: var(--paper-deep);">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Equipa</p>
        <h2>Quem a vai <em>acompanhar</em></h2>
      </div>
      <div class="team__grid">
        <div class="reveal" data-d="1" style="position:relative;">
          <div class="arch arch--photo arch--img">
            <Image src={fotoMarta3} alt="Marta Brito, fundadora da Hipnose Resolve" widths={[480, 800]} sizes="(max-width: 940px) 92vw, 38vw" />
          </div>
        </div>
        <div class="team__bio reveal" data-d="2">
          <h3>Marta Brito</h3>
          <p class="role">Hipnoterapeuta · Fundadora da Hipnose Resolve</p>
          <p>
            Foi modelo profissional dos 16 aos 40 anos sem nunca fazer dieta — e é dessa "Mente Magra"
            que nasce a sua especialidade. Apaixonada pela mente humana desde 2000, a Marta ajuda
            pessoas a desaprender a fome emocional, o tabaco e os hábitos que as prendem, com uma
            abordagem calorosa, prática e profundamente humana. Sem julgamento: escuta, método e a
            convicção tranquila de que a mudança é possível.
          </p>
          <div class="team__chips">
            <span>Emagrecimento</span>
            <span>Cessação Tabágica</span>
            <span>Fertilidade e Hipnoparto</span>
            <span>Mudança de Hábitos</span>
            <span>Atende Portugal & Brasil</span>
          </div>
          <p class="team__note">
            <b>A equipa está a crescer.</b> Em breve, terapeutas dedicadas a Trauma e Vícios,
            Vidas Passadas e Hipnoterapia Infantil — cada área com a especialista certa.
          </p>
          <div style="margin-top:2rem; display:flex; gap:.9rem; flex-wrap:wrap;">
            <a class="btn btn--primary" href="/consultas">Marcar com a Marta</a>
            <a class="btn btn--ghost" href="/equipa">Conhecer a equipa</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMAS -->
  <section class="section programs" id="programas">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Programas de transformação</p>
        <h2>Um método, <em>três caminhos</em></h2>
        <p class="lead" style="margin-top:1.2rem;">Programas guiados que complementam — ou começam — o seu percurso de mudança.</p>
      </div>
      <div class="programs__grid">
        {programas.map((p, i) => (
          <article class="program reveal" data-d={String(i + 1)}>
            <span class="kicker">{p.data.kicker}</span>
            <h3>{p.data.nome}</h3>
            <p>{p.data.sub}</p>
            <p class="cross">Prefere acompanhamento 1-para-1? <a href={`/areas/${p.data.area}`}>Marque uma consulta de {areaNome(p.data.area)}</a>.</p>
            <a class="btn btn--paper" href={`/programas/${p.id}`}>Saber mais</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTEMUNHOS -->
  <section class="section">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Histórias reais</p>
        <h2>O que dizem <em>depois</em></h2>
      </div>
      <div class="quotes__grid">
        <blockquote class="quote reveal" data-d="1">
          <p>Três anos de dietas sem resultado. Com a Marta perdi 20 kg — mudei por dentro, e o resto seguiu.</p>
          <footer><span class="stars" aria-hidden="true">★★★★★</span><b>Maria Ferreira</b> · Programa MagraMente</footer>
        </blockquote>
        <blockquote class="quote reveal" data-d="2">
          <p>Fumei durante 30 anos. Numa sessão de 90 minutos, saí de lá não fumador — e assim fiquei.</p>
          <footer><span class="stars" aria-hidden="true">★★★★★</span><b>J. Paulo Guerreiro</b> · Set You Free</footer>
        </blockquote>
        <blockquote class="quote reveal" data-d="3">
          <p>Perdi 10 kg em dois meses, inteiramente online. Senti-me acompanhada como se estivesse na sala ao lado.</p>
          <footer><span class="stars" aria-hidden="true">★★★★★</span><b>Carine</b> · MagraMente online</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow" style="justify-content:center; display:flex;">Perguntas frequentes</p>
        <h2 style="margin-bottom:2.5rem;">Antes de <em>dar o passo</em></h2>
      </div>
      <div class="faq reveal" data-d="1">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section" style="padding-top:0;">
    <div class="cta-final reveal">
      <h2>O primeiro passo é <em>uma conversa</em>.</h2>
      <p class="lead" style="margin-inline:auto;">Marque a sua Consulta de Avaliação — online ou presencial — e comece o caminho ao seu ritmo.</p>
      <a class="btn btn--primary" href="/consultas">
        Marcar Consulta de Avaliação
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8h11m0 0L9 4m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>
</Base>
