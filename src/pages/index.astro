---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import fotoMarta from '../assets/img/marta.jpeg';
import fotoMarta3 from '../assets/img/marta-3.png';
import fotoMagra from '../assets/img/magramente-1.jpg';
import fotoTabaco from '../assets/img/tabaco.jpeg';
import fotoAnsiedade from '../assets/img/ansiedade.png';
import fotoRelacoes from '../assets/img/relacionamentos.jpg';
import fotoStress from '../assets/img/stress.webp';
import fotoMedos from '../assets/img/medos.jpg';

const programas = (await getCollection('programas')).sort((a, b) => a.data.ordem - b.data.ordem);
const areas = await getCollection('areas');
const areaNome = (id: string) => areas.find((a) => a.id === id)?.data.nome ?? '';

/* ícones linha (traço dourado) */
const ico = {
  pessoa: 'M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 8c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5',
  escudo: 'M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3Zm-2.5 9 2 2 3.5-4',
  estrela: 'M12 3.5l2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4L4.2 9.2l5.4-.8L12 3.5Z',
  spark: 'M12 3v4m0 10v4m9-9h-4M7 12H3m14.5-6.5-2.8 2.8M9.3 14.7l-2.8 2.8m11 0-2.8-2.8M9.3 9.3 6.5 6.5',
  coracao: 'M12 20s-7-4.5-9-9c-1.2-2.8.5-6 3.6-6 1.9 0 3.4 1 4.4 2.6C12 6 13.5 5 15.4 5c3.1 0 4.8 3.2 3.6 6-2 4.5-7 9-7 9Z',
  mente: 'M9 4a5 5 0 0 0-5 5c0 1.5.6 2.8 1.5 3.8L5 18l3.5-1c.8.3 1.6.5 2.5.5M9 4c.8-.6 1.9-1 3-1a8 8 0 0 1 8 8c0 4.4-3.6 8-8 8',
  chave: 'M14 10a4 4 0 1 0-4 4h1v2h2v2h2v2h3v-3l-4-4v-1a4 4 0 0 0 0-2Z',
  calendario: 'M5 6h14a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm3-3v4m8-4v4M4 11h16',
  globo: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm-9-9h18M12 3c2.5 2.4 4 5.6 4 9s-1.5 6.6-4 9c-2.5-2.4-4-5.6-4-9s1.5-6.6 4-9Z',
  balanca: 'M12 4v16m-7 0h14M5 8l3.5 6h-7L5 8Zm14 0 3.5 6h-7L19 8ZM7 5.5 17 4',
};
const Icon = (d: string) => `<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${d}" stroke="currentColor"/></svg>`;

const terapias = [
  { nome: 'Ansiedade e Stress', txt: 'Recupere a calma, o equilíbrio emocional e a leveza de viver sem sobrecarga mental.', href: '/areas/ansiedade-panico', img: fotoAnsiedade, icone: ico.mente },
  { nome: 'Autoestima e Confiança', txt: 'Transforme a forma como se vê e fortaleça o que a sua voz interior lhe diz.', href: '/areas/autoestima-empoderamento', img: fotoRelacoes, icone: ico.coracao },
  { nome: 'Hábitos e Comportamentos', txt: 'Elimine padrões limitantes e crie novos hábitos que impulsionam a sua melhor versão.', href: '/areas/mudanca-habitos', img: fotoStress, icone: ico.spark },
  { nome: 'Emagrecimento Consciente', txt: 'Reprograme a sua mente para alcançar o peso ideal de forma saudável e definitiva.', href: '/areas/emagrecimento', img: fotoMagra, icone: ico.balanca },
  { nome: 'Parar de Fumar', txt: 'Liberte-se do tabaco com apoio especializado e hipnose clínica — numa única sessão.', href: '/areas/cessacao-tabagica', img: fotoTabaco, icone: ico.escudo },
  { nome: 'E muito mais…', txt: 'Fobias, luto, fertilidade, trauma e outros desafios que pode superar connosco.', href: '/areas', img: fotoMedos, icone: ico.chave },
];

const pilares = [
  { txt: 'Abordagem clínica e personalizada', icone: ico.pessoa },
  { txt: 'Confidencialidade e ética profissional', icone: ico.escudo },
  { txt: 'Terapeutas especialistas em formação contínua', icone: ico.estrela },
  { txt: 'Métodos comprovados e tecnologia', icone: ico.spark },
  { txt: 'Acompanhamento antes, durante e depois', icone: ico.coracao },
];

const porque = [
  { txt: 'Planos 100% personalizados, feitos à sua medida', icone: ico.pessoa },
  { txt: 'Métodos clínicos eficazes e fundamentados', icone: ico.estrela },
  { txt: 'Estamos consigo antes, durante e depois do processo', icone: ico.calendario },
  { txt: 'Um espaço seguro, onde pode ser quem realmente é', icone: ico.coracao },
  { txt: 'Ferramentas avançadas que potenciam a transformação', icone: ico.spark },
];

const faq = [
  { q: 'A hipnose é segura? Vou perder o controlo?', a: 'Sim, é segura — e não, nunca perde o controlo. Em hipnoterapia clínica está sempre consciente e no comando; a terapeuta apenas guia um estado de foco profundo, semelhante ao de estar absorto num bom livro.' },
  { q: 'As sessões online funcionam tão bem como as presenciais?', a: 'Sim. A hipnoterapia adapta-se muito bem ao formato online: basta um lugar tranquilo, auscultadores e ligação estável. O link da sessão chega automaticamente com a confirmação.' },
  { q: 'Qual a diferença entre a Consulta de Avaliação e a de Tratamento?', a: 'A Avaliação (2h) é o ponto de partida: conhecer a sua história e definir o plano. As consultas de Tratamento (1h) são as sessões de acompanhamento contínuo desse plano.' },
  { q: 'A hipnoterapia substitui o médico ou psicólogo?', a: 'Não. É uma prática complementar de bem-estar e não substitui diagnóstico nem tratamento médico ou psicológico. Sempre que necessário, trabalhamos em articulação com outros profissionais de saúde.' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalBusiness',
    name: 'Hipnose Resolve',
    description: 'Clínica de hipnoterapia — reprogramamos mentes e comportamentos. Consultas online e presenciais, Portugal e Brasil.',
    url: 'https://hipnoseresolve.pt',
    telephone: '+351915574759',
    email: 'info@hipnoseresolve.pt',
    address: { '@type': 'PostalAddress', streetAddress: 'Rua Dr. Álvaro Monteiro, 12 R/C dto.', postalCode: '3510-014', addressLocality: 'Viseu', addressCountry: 'PT' },
    founder: { '@type': 'Person', name: 'Marta Brito', jobTitle: 'Hipnoterapeuta' },
    sameAs: ['https://www.instagram.com/hipnoseresolve/', 'https://www.facebook.com/profile.php?id=61555999870032'],
    areaServed: ['PT', 'BR'],
    availableLanguage: 'pt',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Base
  title="Hipnose Resolve — Clínica de Hipnoterapia · Online e Presencial"
  description="Reprogramamos mentes e comportamentos. Transformamos vidas. Hipnose clínica para ansiedade, hábitos, emagrecimento e cessação tabágica — online e presencial, Portugal e Brasil."
  schema={schema}
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero__grid">
      <div>
        <p class="eyebrow" data-rise="1">Clínica de Hipnoterapia · Online e Presencial</p>
        <h1 data-rise="2">Reprogramamos mentes e comportamentos.<br /><em>Transformamos vidas.</em></h1>
        <p data-rise="3" style="margin-top:1.6rem; font-weight:600; font-size:1.12rem; max-width:44ch;">
          Hipnose clínica, inteligência emocional e método ao serviço da sua transformação.
        </p>
        <p class="lead" data-rise="3" style="margin-top:.8rem; font-size:1.02rem;">
          Acreditamos que está sempre a tempo de ser feliz — e estamos aqui para o ajudar
          a conquistar a vida que deseja.
        </p>
        <div class="hero__cta" data-rise="4">
          <a class="btn btn--primary" href="/consultas">
            Quero transformar a minha vida
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8h11m0 0L9 4m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a class="btn btn--ghost" href="/consultas">Ver como funciona</a>
        </div>
        <div class="hero__proof" data-rise="5">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span>Sessões online com link automático</span>
          <span aria-hidden="true">·</span>
          <span>Portugal e Brasil, em português</span>
        </div>
      </div>
      <div style="position:relative;" data-rise="3">
        <div class="arch arch--img">
          <Image src={fotoMarta} alt="Marta Brito, hipnoterapeuta e fundadora da Hipnose Resolve" widths={[480, 800, 1100]} sizes="(max-width: 940px) 92vw, 44vw" loading="eager" />
        </div>
        <div class="chip-float" style="top:9%; left:-4%;">
          <span class="dot"></span> Sessão confirmada — link enviado
        </div>
        <div class="chip-float" style="bottom:14%; right:-3%;">
          Online e presencial
        </div>
      </div>
    </div>
  </section>

  <!-- FAIXA DE CONFIANÇA -->
  <section class="trust" aria-label="Os nossos pilares">
    <div class="wrap trust__grid">
      {pilares.map((p) => (
        <div class="trust__item reveal">
          <Fragment set:html={Icon(p.icone)} />
          <span>{p.txt}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- TERAPIAS -->
  <section class="section" id="terapias">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow" style="justify-content:center; display:flex;">Áreas em que podemos ajudar</p>
        <h2>Terapias que <em>transformam vidas</em></h2>
      </div>
      <div class="thera">
        {terapias.map((t, i) => (
          <a class="thera-card reveal" data-d={String(i % 3)} href={t.href}>
            <div class="thera-card__img">
              <Image src={t.img} alt={t.nome} widths={[420, 700]} sizes="(max-width: 980px) 92vw, 30vw" />
            </div>
            <div class="thera-card__ico"><Fragment set:html={Icon(t.icone)} /></div>
            <div class="thera-card__body">
              <h3>{t.nome}</h3>
              <p>{t.txt}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="reveal" style="text-align:center; margin-top:2.8rem;">
        <a class="btn btn--primary" href="/areas">Ver todas as terapias</a>
      </div>
    </div>
  </section>

  <!-- FUNDADORA -->
  <section class="section" style="background: var(--paper-deep); padding-block: clamp(3.5rem, 8vw, 6rem);">
    <div class="wrap team__grid" style="margin-top:0;">
      <div class="reveal" style="position:relative;">
        <div class="arch arch--photo arch--img">
          <Image src={fotoMarta3} alt="Marta Brito, fundadora da Hipnose Resolve" widths={[480, 800]} sizes="(max-width: 940px) 92vw, 38vw" />
        </div>
      </div>
      <div class="team__bio reveal" data-d="1">
        <p class="eyebrow">Conheça a fundadora</p>
        <h2 style="font-size: clamp(1.9rem, 3.4vw, 2.8rem);">Olá, sou a <em>Marta Brito</em>.</h2>
        <p style="margin-top:1.2rem;">
          A Hipnose Resolve nasceu da minha vontade de ajudar pessoas a reescreverem a sua história.
          Acredito profundamente que todas merecem a oportunidade de transformarem a sua vida —
          e de viverem com leveza, liberdade e propósito.
        </p>
        <p style="margin-top:.9rem;">
          Cada protocolo, cada sessão e cada detalhe da nossa clínica foram criados com um único
          objetivo: fazer realmente a diferença na vida de quem confia em nós.
        </p>
        <p style="margin-top:1.4rem; font-family:var(--serif); font-style:italic; font-size:1.25rem; color:#8A6E37;">
          Estou aqui para caminhar consigo.
        </p>
        <div style="margin-top:1.8rem;">
          <a class="btn btn--ghost" href="/equipa/marta">Conhecer a minha história</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PORQUÊ -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow" style="justify-content:center; display:flex;">Porquê a Hipnose Resolve?</p>
        <h2 style="max-width:24ch; margin-inline:auto;">Mais do que terapia, uma <em>experiência de transformação</em>.</h2>
      </div>
      <div class="trust__grid reveal" data-d="1" style="padding-top:3rem;">
        {porque.map((p) => (
          <div class="trust__item">
            <Fragment set:html={Icon(p.icone)} />
            <span>{p.txt}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NÚMEROS (reais) -->
  <section class="stats" aria-label="Resultados">
    <div class="wrap stats__grid">
      <div class="stat reveal"><Fragment set:html={Icon(ico.balanca)} /><b>−20 kg</b><span>a maior transformação MagraMente</span></div>
      <div class="stat reveal" data-d="1"><Fragment set:html={Icon(ico.escudo)} /><b>90 min</b><span>para apagar 30 anos de tabaco</span></div>
      <div class="stat reveal" data-d="2"><Fragment set:html={Icon(ico.mente)} /><b>Desde 2000</b><span>a estudar a mente humana</span></div>
      <div class="stat reveal" data-d="3"><Fragment set:html={Icon(ico.globo)} /><b>PT · BR</b><span>consultas online nos dois fusos</span></div>
    </div>
  </section>

  <!-- PROGRAMAS -->
  <section class="section" id="programas">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow" style="justify-content:center; display:flex;">Programas de transformação</p>
        <h2>Um método, <em>três caminhos</em></h2>
      </div>
      <div class="cards">
        {programas.map((p, i) => (
          <a class="card-l reveal" data-d={String(i)} href={`/programas/${p.id}`}>
            <span class="kicker">{p.data.kicker}</span>
            <h3>{p.data.nome}</h3>
            <p>{p.data.sub}</p>
            <span class="mais">{p.data.comprarOnline ? 'Comprar online →' : 'Conhecer o programa →'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTEMUNHOS -->
  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow" style="justify-content:center; display:flex;">Histórias reais, resultados reais</p>
        <h2>O que dizem <em>sobre nós</em></h2>
      </div>
      <div class="quotes__grid">
        <blockquote class="quote reveal" data-d="1">
          <p>Três anos de dietas sem resultado. Com a Marta perdi 20 kg — mudei por dentro, e o resto seguiu.</p>
          <footer><span class="quote__avatar" aria-hidden="true">MF</span><span><b>Maria Ferreira</b><br /><span style="font-size:.82rem;">Programa MagraMente</span></span></footer>
        </blockquote>
        <blockquote class="quote reveal" data-d="2">
          <p>Fumei durante 30 anos. Numa sessão de 90 minutos, saí de lá não fumador — e assim fiquei.</p>
          <footer><span class="quote__avatar" aria-hidden="true">JP</span><span><b>J. Paulo Guerreiro</b><br /><span style="font-size:.82rem;">Set You Free</span></span></footer>
        </blockquote>
        <blockquote class="quote reveal" data-d="3">
          <p>Perdi 10 kg em dois meses, inteiramente online. Senti-me acompanhada como se estivesse na sala ao lado.</p>
          <footer><span class="quote__avatar" aria-hidden="true">C</span><span><b>Carine</b><br /><span style="font-size:.82rem;">MagraMente online</span></span></footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;">
        <p class="eyebrow" style="justify-content:center; display:flex;">Perguntas frequentes</p>
        <h2 style="margin-bottom:2.5rem;">Antes de <em>dar o passo</em></h2>
      </div>
      <div class="faq reveal" data-d="1">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section" style="padding-top:0;">
    <div class="cta-final reveal">
      <div class="cta-final__grid">
        <div style="text-align:left; max-width: 52ch;">
          <h2 style="margin-inline:0;">A sua nova história <em>começa agora</em>.</h2>
          <p class="lead" style="margin:1.2rem 0 2rem;">Dê o primeiro passo para transformar a sua vida. Estamos aqui para a ajudar.</p>
          <div style="display:flex; gap:.9rem; flex-wrap:wrap;">
            <a class="btn btn--primary" href="/consultas">
              Marcar Consulta de Avaliação
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8h11m0 0L9 4m4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a class="btn btn--ghost" href="https://wa.me/351915574759" target="_blank" rel="noopener">Falar com a terapeuta</a>
          </div>
        </div>
        <div class="selo" aria-hidden="true">Acreditamos em si, mesmo antes de voltar a acreditar em si próprio.</div>
      </div>
    </div>
  </section>
</Base>
