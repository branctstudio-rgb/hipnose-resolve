---
import Base from '../layouts/Base.astro';
import { WA_URL } from '../config/site';
/* Área de Membros SEM backend: não renderizamos formulário de login nem
   recolhemos credenciais. Quando featureFlags.membersAreaEnabled = true e
   houver autenticação real (Supabase/CRM), restaurar o fluxo de login. */
---
<Base
  title="Área exclusiva em preparação — Hipnose Resolve"
  description="A área de membros da Hipnose Resolve está em preparação. Em breve, os participantes dos programas poderão aceder aqui aos seus conteúdos exclusivos."
  noindex={true}
>
  <section class="login-wrap wrap">
    <div class="login-card reveal in" style="text-align:center;">
      <p class="eyebrow" style="margin-bottom:.8rem;">Área de Membros</p>
      <h1>Área exclusiva em <em>preparação</em></h1>
      <p class="lead" style="margin-inline:auto;">
        Em breve, os participantes dos programas poderão aceder aqui aos seus
        conteúdos exclusivos — áudios de hipnose, ebooks e materiais de apoio.
      </p>
      <div style="display:flex; gap:.9rem; flex-wrap:wrap; justify-content:center; margin-top:2rem;">
        <a class="btn btn--gold" href="/programas">Conhecer os programas</a>
        <a class="btn btn--ghost" href={WA_URL} target="_blank" rel="noopener noreferrer">Falar com a equipa</a>
      </div>
    </div>
  </section>
</Base>
